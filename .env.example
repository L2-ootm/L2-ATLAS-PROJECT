# ATLAS environment configuration template.
#
# Copy this file to `.env` (gitignored) in the repo root and fill in real
# values there. NEVER commit a real `.env` file or paste a real API key into
# this template — `.env.example` must only ever contain variable names and
# `env:VAR` reference syntax, never an actual secret value.
#
# Every variable below is read by the code paths named in its comment; blank
# means "use the built-in default". Vendored donor-TUI flags (ATLAS_TUI_EXPERIMENTAL_*
# etc.) are internal and intentionally not listed here.
#
# PORT AUTHORITY NOTE (read this before touching ~/.atlas/config.yaml):
# `~/.atlas/config.yaml`'s `gateway.rust_port` / `cockpit.port` fields are
# informational only and are NOT read by `atlas up` today — nothing wires
# them into the actual spawn command. The environment variables below
# (ATLAS_GATEWAY_PORT / ATLAS_GATEWAY_URL / ATLAS_COCKPIT_URL) are
# authoritative for the gateway/cockpit spawn + health-check URLs that
# `gateway_control.py` / `cockpit_control.py` actually use. If you change a
# port, change it here — editing config.yaml alone will not take effect.

# --- Provider -----------------------------------------------------------
# ATLAS never stores a literal API key in config. The provider's api_key
# field is always an "env:VAR_NAME" reference; set the real secret in your
# shell environment or in this gitignored .env file, under the variable
# name your reference points at. Example reference variable name below —
# set your key here, never commit it.
ATLAS_PROVIDER_API_KEY_REF=env:ATLAS_PROVIDER_API_KEY
# ATLAS_PROVIDER_API_KEY=

# --- Gateway (Rust; gateway_control.py + atlas-gateway/src/lib.rs) ---------
ATLAS_GATEWAY_PORT=8484
ATLAS_GATEWAY_URL=http://127.0.0.1:8484
# Path to the atlas-gateway binary. Blank: PATH lookup, then
# native/atlas-core-rs/target/release.
ATLAS_GATEWAY_BIN=
# Command the gateway dispatches writes through (split on whitespace).
# Blank: `atlas` on PATH; gateway_control auto-injects
# "<python> -m atlas_runtime.cli.main" in dev when unset.
ATLAS_CLI=
# Extra comma-separated CORS origins on top of the built-in local allowlist.
ATLAS_CORS_ORIGINS=
# SQLite database path override. Blank: ~/.atlas/atlas.db.
ATLAS_DB=
# Repo root override for gateway-side path resolution. Blank: auto-detected.
ATLAS_REPO_ROOT=

# --- Cockpit (React; cockpit_control.py) -----------------------------------
ATLAS_COCKPIT_URL=http://127.0.0.1:5173

# --- Database / state home --------------------------------------------------
# Left blank: defaults to ~/.atlas (config.yaml, atlas.db, wiki/, pid files).
# Set only if you want ATLAS state isolated to a non-default directory.
ATLAS_HOME=

# --- Logging (logging_config.py) ---------------------------------------------
# Rotating file log at <ATLAS_HOME>/logs/atlas.log (5MB x3).
# Level: DEBUG | INFO | WARNING | ERROR. Blank: INFO.
ATLAS_LOG_LEVEL=
# Log directory override. Blank: <ATLAS_HOME>/logs.
ATLAS_LOG_DIR=
# Hermes foundation home override (auth_service). Blank: default resolution.
HERMES_HOME=

# --- Terminals (cli/go_tui.py, services/atlas-terminal) ---------------------
# Path to the Go atlas-tui binary. Blank: PATH, then checkout build.
ATLAS_TUI_BIN=
# atlas-terminal (donor TUI) reads ATLAS_GATEWAY_URL above for its gateway.

# --- FreeLLMAPI sidecar (freellmapi_control.py, model_registry.py) ----------
# OpenAI-compatible local gateway base URL. Blank: http://127.0.0.1:3001/v1.
ATLAS_LLM_GATEWAY_URL=
# API key sent to that gateway, when it requires one.
ATLAS_LLM_GATEWAY_KEY=
# Checkout directory of the freellmapi repo. Blank: _EXTERNAL_REPOS/freellmapi
# or a sibling clone.
ATLAS_FREELLMAPI_DIR=

# --- Discord sidecar (discord_control.py, discord_api.py) -------------------
# The vendored bot's HTTP API. Blank: http://localhost:8081.
ATLAS_DISCORD_BOT_URL=
# Bot checkout directory. Blank: services/discord-bot.
ATLAS_DISCORD_DIR=
# Python interpreter for the bot's own venv. Blank: sidecar venv resolution.
ATLAS_DISCORD_PYTHON=

# --- Cashflow module (cashflow_control.py, gateway) -------------------------
# The Next.js cashflow app. Blank: http://localhost:3000.
ATLAS_CASHFLOW_URL=
# SQLite path the gateway reads cashflow data from. Blank:
# services/cashflow/dev.db (injected by gateway_control at spawn).
ATLAS_CASHFLOW_DB_PATH=

# --- Messaging channels (cli/channels.py) -----------------------------------
# CLI command for the messaging gateway sidecar (split on whitespace).
ATLAS_MESSAGING_CLI=

# --- Knowledge graph scopes (graph_service.py) -------------------------------
# Obsidian vault root for the `obsidian` graph scope.
ATLAS_OBSIDIAN_DIR=
# Projects directory for the `projects` graph scope.
ATLAS_PROJECTS_DIR=

# --- Auth import sources (secure_store.py, codex_auth.py) --------------------
# Where `atlas auth import` looks for existing CLI credentials.
# Blank: ~/.codex and ~/.claude.
CODEX_HOME=
CLAUDE_CONFIG_DIR=
