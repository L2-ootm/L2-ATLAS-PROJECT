# Normalize source/docs to LF in the repository.
* text=auto eol=lf

# Windows command scripts should remain CRLF for native Windows tooling.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary/media files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.docx binary
*.zip binary
*.7z binary
*.db binary
*.sqlite binary
*.sqlite3 binary
