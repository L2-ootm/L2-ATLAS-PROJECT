{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@tsconfig/bun/tsconfig.json",
	"compilerOptions": {
		"jsx": "preserve",
		"jsxImportSource": "@opentui/solid",
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"bun"
		],
		"noUncheckedIndexedAccess": false,
		"customConditions": [
			"browser"
		],
		"paths": {
			"@/*": [
				"./src/vendor/opencode/*"
			],
			"@tui/*": [
				"./src/tui/*"
			],
			"@atlas/sdk/v2": [
				"./src/sdk/v2/index.ts"
			],
			"@atlas/sdk/v2/*": [
				"./src/sdk/v2/*"
			],
			"@atlas/plugin": [
				"./src/vendor/plugin/index.ts"
			],
			"@atlas/plugin/tui": [
				"./src/vendor/plugin/tui.ts"
			],
			"@atlas/shared/*": [
				"./src/vendor/shared/*"
			],
			"@atlas/ui/*": [
				"./src/vendor/ui/*"
			],
			"@/cli/cmd/tui/*": [
				"./src/tui/*"
			]
		},
		"noPropertyAccessFromIndexSignature": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noImplicitAny": false
	},
	"include": [
		"src",
		"test"
	]
}
